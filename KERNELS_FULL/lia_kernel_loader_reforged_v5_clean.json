        "observability_change"
      ]
    },
    "reference_pseudocode": {
      "class_name": "KernelLoader",
      "language": "python",
      "skeleton": [
        "__init__",
        "ingest",
        "normalize",
        "recursive_feedback",
        "compute_energy",
        "fuse",
        "narrate",
        "persist"
      ],
      "core_methods": {
        "recursive_feedback": "(w_f * x_f + w_b * x_b) / (w_f + w_b + epsilon)",
        "compute_energy": "K * A * R * F * S",
        "fuse": "weighted sum of agent outputs with normalized weights"
      }
    },
    "implementation_guidance": {
