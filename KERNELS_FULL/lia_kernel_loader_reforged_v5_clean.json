      },
      "governance_interventions": {
        "symbol": "g",
        "range": [
          0,
          "unbounded"
        ],
        "meaning": "policy events requiring review"
      },
      "coherence": {
        "symbol": "C",
        "range": [
          0,
          1
        ],
        "meaning": "narrative and structural consistency"
      },
      "entropy": {
        "symbol": "H_e",
        "range": [
          0,
          1
        ],
        "meaning": "information spread / unpredictability"
      }
    },
    "governance": {
      "principles": [
        "policy_first",
        "audit_every_mutation",
        "separate_symbol_from_authority",
        "rollback_required_for_core_changes",
        "narrative_must_not_override_measured_state"
      ],
      "controls": {
        "self_modification": "policy_checked",
        "privileged_transition": "audited",
        "external_interaction": "bounded",
        "persistence_write": "versioned",
        "unsafe_action": "blocked_or_quarantined"
      },
      "failure_modes": [
        "governance_violation",
        "state_inconsistency",
        "energy_instability",
        "memory_collision",
        "fusion_conflict"
      ]
    },
    "canonical_data_model": {
      "event": {
        "fields": [
          "event_id",
          "timestamp",
          "source",
          "target_organ",
          "input_payload",
          "transformed_payload",
