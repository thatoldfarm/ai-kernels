    "closing_frame": {
      "thesis": "The kernel is strongest when it behaves like a disciplined recursive operating framework with a symbolic interface.",
      "goal": "Preserve identity, remove ambiguity, formalize data flow, and make the system testable and extensible."
    }
  }
