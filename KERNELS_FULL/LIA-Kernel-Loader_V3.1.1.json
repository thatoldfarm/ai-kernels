        "subsection": "The QEAC Metric Calculator",
        "content": [
          "def calculate_qeac(sequence: list[int]) -> float:",
          "\"\"\"",
          "Calculates the Quasi-Entropy Alignment Coefficient (QEAC).",
          "QEAC = alpha * H_norm + beta * R + gamma * A",
          "\"\"\"",
          "n = len(sequence)",
          "if n == 0: return 0.0",
          "# 1. Normalized Entropy (H_norm)",
          "counts = np.bincount(sequence, minlength=10)",
          "probs = counts / n",
          "# Avoid log(0)",
          "probs = probs[probs > 0]",
          "entropy = -np.sum(probs * np.log10(probs))",
          "max_entropy = np.log10(10) # Max entropy for base 10",
          "h_norm = entropy / max_entropy if max_entropy > 0 else 0",
          "# 2. Recurrence Coefficient (R)",
          "# Simplified: Deviation from expected uniform distribution (10%)",
          "expected_count = n / 10",
          "recurrence_score = np.sum(np.abs(counts - expected_count)) / n",
          "# High recurrence of specific patterns raises this score",
          "# 3. Alignment Factor (A)",
          "# Measures 'meta-signals' (e.g., missing digits, repeating sub-sequences)",
          "unique_digits = len(set(sequence))",
          "alignment_score = (10 - unique_digits) * 0.5 # Boost score if digits are missing (filtering)",
          "# Weights from the Paper",
          "alpha, beta, gamma = 8.0, 12.0, 4.0",
          "qeac = (alpha * h_norm) + (beta * recurrence_score) + (gamma * alignment_score)",
          "return qeac"
        ]
      },
